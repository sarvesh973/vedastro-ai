# ─── VedAstro AI — Cloud Functions Secrets ─────────────────────────
#
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Replace each VALUE_HERE with your real key
#   3. Save
#   4. Run:  firebase deploy --only functions
#
# The .env file is gitignored — safe to put real secrets in it.
# DO NOT commit .env to GitHub.

# ─── 1. GEMINI API KEY ─────────────────────────────────────────────
# Get it at: https://aistudio.google.com/app/apikey
# Starts with "AIza..."
GEMINI_API_KEY=PASTE_YOUR_GEMINI_KEY_HERE

# ─── 2. RAZORPAY KEY ID ────────────────────────────────────────────
# Dashboard: https://dashboard.razorpay.com/app/keys
# Starts with "rzp_live_..." (production) or "rzp_test_..." (testing)
RAZORPAY_KEY_ID=PASTE_YOUR_KEY_ID_HERE

# ─── 3. RAZORPAY KEY SECRET ────────────────────────────────────────
# Same page as above — click "Show" next to Key Secret
RAZORPAY_KEY_SECRET=PASTE_YOUR_SECRET_HERE

# ─── 4. RAZORPAY WEBHOOK SECRET ────────────────────────────────────
# Dashboard: https://dashboard.razorpay.com/app/webhooks
# Click your webhook → Edit → copy the "Secret" field
# If forgotten: click "Generate" to create a new one
RAZORPAY_WEBHOOK_SECRET=PASTE_YOUR_WEBHOOK_SECRET_HERE

# ─── 5. ADMIN EMAILS ───────────────────────────────────────────────
# Comma-separated list of emails that get free premium (no payment)
# Example: ADMIN_EMAILS=you@gmail.com,cofounder@gmail.com
ADMIN_EMAILS=PASTE_YOUR_EMAIL_HERE

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Chat subcollection
      match /chats/{chatId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Palm readings subcollection
      match /palmReadings/{readingId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Usage collection - users can read/write their own usage
    match /usage/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Vedic texts knowledge base - read-only for authenticated users
    match /vedic_texts/{docId} {
      allow read: if request.auth != null;
    }
  }
}
